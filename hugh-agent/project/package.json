{
  "name": "flex-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite --open",
    "dev:backend": "convex dev",
    "build": "vite build",
    "lint": "tsc -p convex -noEmit --pretty false && tsc -p . -noEmit --pretty false && convex dev --once && vite build",
    "test": "./scripts/run-integration-tests.sh",
    "test:quick": "./scripts/run-integration-tests.sh --quick",
    "test:file": "./scripts/run-integration-tests.sh --file",
    "test:watch": "./scripts/run-integration-tests.sh --watch",
    "test:coverage": "./scripts/run-integration-tests.sh --coverage",
    "test:jest": "jest"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.80",
    "@hono/node-server": "^1.19.11",
    "@types/file-saver": "^2.0.7",
    "@types/mapbox-gl": "^3.4.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.2",
    "file-saver": "^2.0.5",
    "hono": "^4.12.9",
    "jszip": "^3.10.1",
    "livekit-server-sdk": "^2.15.0",
    "mapbox-gl": "^3.20.0",
    "node-ssh": "^13.2.1",
    "openai": "^6.32.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sonner": "^2.0.3",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.1.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "~10",
    "dotenv": "^16.4.7",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "postcss": "~8",
    "prettier": "^3.5.3",
    "tailwindcss": "~3",
    "ts-jest": "^29.1.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0"
  }
}
