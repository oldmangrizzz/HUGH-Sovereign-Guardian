# H.U.G.H. Agent Configuration

# Unique identifier for this node (e.g., macbook-air, vps-kvm4)
NODE_ID=macbook-air

# Secret for authenticating requests from Convex
KVM_AGENT_SECRET=your-secret-here

# Port to listen on (default: 7734)
PORT=7734

# Convex deployment URL (visible in .env.local as CONVEX_URL)
CONVEX_URL=https://your-deployment.convex.cloud

# Convex site URL for HTTP actions
CONVEX_SITE_URL=https://your-deployment.convex.site

# Use spontaneous Cloudflare tunnel on startup
USE_TUNNEL=true

# Domain for tunnel (requires CF credentials if using custom subdomain)
TUNNEL_DOMAIN=GrizzlyMedicine.ICU

# HuggingFace token (for model downloads / uploads)
HF_TOKEN=your-hf-token-here
