FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir "mcp>=1.3,<1.4" proxmoxer requests pydantic fastapi uvicorn

COPY src/ /app/src/
COPY proxmox-config/ /app/proxmox-config/

ENV PROXMOX_MCP_CONFIG="/app/proxmox-config/config.json"
ENV PYTHONPATH="/app"

CMD ["python3", "-m", "proxmox_mcp.server"]
